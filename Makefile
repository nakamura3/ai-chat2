.PHONY: install dev build start lint typecheck deploy help

# デフォルトターゲット
.DEFAULT_GOAL := help

# --------------------------------------------------------------------------
# セットアップ
# --------------------------------------------------------------------------

install: ## 依存パッケージをインストールする
	npm install

# --------------------------------------------------------------------------
# 開発
# --------------------------------------------------------------------------

dev: ## 開発サーバーを起動する (http://localhost:3000)
	npm run dev

typecheck: ## TypeScript の型チェックを実行する
	npx tsc --noEmit

lint: ## ESLint を実行する
	npm run lint

# --------------------------------------------------------------------------
# ビルド
# --------------------------------------------------------------------------

build: ## 本番用ビルドを実行する
	npm run build

start: build ## 本番ビルド後にサーバーを起動する
	npm run start

# --------------------------------------------------------------------------
# デプロイ
# --------------------------------------------------------------------------

deploy: ## Vercel へデプロイする（要: vercel CLI ログイン済み）
	npx vercel deploy --prod

deploy-preview: ## Vercel へプレビューデプロイする
	npx vercel deploy

# --------------------------------------------------------------------------
# ユーティリティ
# --------------------------------------------------------------------------

clean: ## .next キャッシュと node_modules を削除する
	rm -rf .next node_modules

help: ## 使用可能なコマンドを表示する
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) \
		| awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-18s\033[0m %s\n", $$1, $$2}'
